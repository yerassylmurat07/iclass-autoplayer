# ══════════════════════════════════════════════════════════
#  Moodle Lecture Parser — Конфигурация
#  Скопируй в .env и заполни своими данными
#  ⚠️  НИКОГДА не коммить .env в git!
# ══════════════════════════════════════════════════════════

# Базовый URL портала (без /login/index.php)
MOODLE_URL=https://learn.inha.ac.kr

# Логин (email / студенческий ID)
MOODLE_LOGIN=ваш_студенческий_id

# Пароль
MOODLE_PASSWORD=ваш_пароль
